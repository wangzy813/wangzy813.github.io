<div id="players-summary" style="margin-top:6px;line-height:1.9"></div>
</details>

<div class="footer-note">每日打开即可看到最新排名 · 数据来源：腾讯证券 · 上月收盘价 = 6月30日收盘价</div>
</div>

<script>
(function(){
// ============ 第四届天才杯 配置 ============
var MONTH_LABEL = '2026年6月';
// 上月收盘价（5月29日收盘价，作为月涨幅基准）
var PREV_MONTH_CLOSE = {
  '600367':32.09, '600487':77.12, '002735':14.80, '603738':43.42,
  '600573':13.33, '002281':203.95, '603005':41.04, '600601':13.43,
  '600489':22.42, '002463':132.04, '000559':14.78, '000977':64.63,
  '600577':13.00, '002580':24.24, '600584':82.05, '601231':44.82,
  '300561':20.92
};
var PLAYERS = [
  '600367|红星发展|三安拿2年','600487|亨通光电|只核小学生','002735|王子新材|忆',
  '603738|泰晶科技|放下执念 跟随市场','600573|惠泉啤酒|努力回本','002281|光迅科技|李瞎浪',
  '603005|晶方科技|主力的狗腿子','600601|方正科技|掌管恒科的神-亏的不知道说啥了',
  '600489|中金黄金|fucker man','002463|沪电股份|Sasa','000559|万向钱潮|巨人的肩膀',
  '000977|浪潮信息|加仓回本','600577|精达股份|cnm大A','002580|圣阳股份|Hudson🐳',
  '600584|长电科技|江苏长电科技股份有限公司','601231|环旭电子|傻逼通威','300561|汇金科技|点点圈圈丶'
].map(function(s){ var p=s.split('|'); return {code:p[0],name:p[1],player:p[2]}; });

// 参赛名单摘要
var ps='';
PLAYERS.forEach(function(p,i){ ps+=(i+1)+'. '+p.player+' → '+p.name+'('+p.code+')<br>'; });
document.getElementById('players-summary').innerHTML = ps;

// ---- 拉所有股票行情（腾讯 qt.gtimg.cn，跨域XHR） ----
function fetchAll(callback){
  var results = [];
  var done = 0;
  PLAYERS.forEach(function(p, idx){
    var prefix = p.code.startsWith('6') ? 'sh' : 'sz';
    var xhr = new XMLHttpRequest();
    xhr.timeout = 15000;
    xhr.onload = function(){
      try{
        var m = xhr.responseText.match(/"([^"]+)"/);
        if(m){
          var parts = m[1].split('~');
          var cur = parseFloat(parts[3]);  // 当前价
          var base = PREV_MONTH_CLOSE[p.code];
          // 月涨幅 = (当前价 - 上月收盘) / 上月收盘
          var pct = (cur && base>0) ? (cur-base)/base*100 : null;
          results[idx] = {code:p.code,name:p.name,player:p.player,base:base,cur:cur,pct:pct};
        } else { results[idx]={code:p.code,name:p.name,player:p.player,base:PREV_MONTH_CLOSE[p.code],cur:null,pct:null}; }
      }catch(e){ results[idx]={code:p.code,name:p.name,player:p.player,base:PREV_MONTH_CLOSE[p.code],cur:null,pct:null}; }
      done++; if(done>=PLAYERS.length){ callback(results); }
    };
    xhr.onerror = xhr.ontimeout = function(){
      results[idx] = {code:p.code,name:p.name,player:p.player,base:PREV_MONTH_CLOSE[p.code],cur:null,pct:null};
      done++; if(done>=PLAYERS.length){ callback(results); }
    };
    xhr.open('GET','https://qt.gtimg.cn/q='+prefix+p.code);
    xhr.send();
  });
}

fetchAll(function(data){
  // 按涨幅降序
  var valid = data.filter(function(d){return d.pct!==null;});
  valid.sort(function(a,b){return b.pct - a.pct;});
  var rankMap = {};
  valid.forEach(function(d,i){ rankMap[d.code] = i+1; });
  data.forEach(function(d){ d.rank = rankMap[d.code] || null; });

  var top3 = valid.slice(0,3);

  // 填入领奖台
  function fill(id, d){
    if(!d) return;
    document.getElementById(id+'-player').textContent = d.player;
    document.getElementById(id+'-stock').textContent = d.name+' ('+d.code+')';
    var sign = d.pct>=0?'+':'';
    document.getElementById(id+'-chg').textContent = sign+d.pct.toFixed(2)+'%';
    document.getElementById(id+'-chg').className = 'pc-chg '+(d.pct>=0?'up':'down');
  }
  fill('g', top3[0]);
  fill('s', top3[1]);
  fill('b', top3[2]);

  // 排名表
  var rows='';
  data.forEach(function(d){
    var cls='', rankTd='-', rowClass='';
    if(d.pct!==null){
      cls = d.pct>=0?'up':'down';
      if(d.rank===1){ rowClass='row-1'; rankTd='🥇 1'; }
      else if(d.rank===2){ rowClass='row-2'; rankTd='🥈 2'; }
      else if(d.rank===3){ rowClass='row-3'; rankTd='🥉 3'; }
      else rankTd = ''+d.rank;
    } else { cls='na'; }
    rows+='<tr class="'+rowClass+'">'+
      '<td style="font-weight:700">'+rankTd+'</td>'+
      '<td style="font-weight:600">'+d.name+'</td>'+
      '<td style="color:#999;font-size:.7rem">'+d.code+'</td>'+
      '<td>'+d.player+'</td>'+
      '<td>'+(d.base?d.base.toFixed(2):'--')+'</td>'+
      '<td class="'+cls+'">'+(d.cur!==null?d.cur.toFixed(2):'--')+'</td>'+
      '<td class="'+cls+'" style="font-weight:600">'+(d.pct!==null?(d.pct>=0?'+':'')+d.pct.toFixed(2)+'%':'--')+'</td>'+
    '</tr>';
  });
  document.getElementById('ranking-body').innerHTML = rows;
  document.getElementById('cup-meta').textContent = MONTH_LABEL+' · 比赛进行中 · 共'+PLAYERS.length+'人参赛';
});
})();
</script>

<!-- ============ 往届回顾（文档链接） ============ -->
<div class="history-section" id="history-section">
<h3>📜 往届回顾</h3>
<div class="history-links" id="history-links">
  <span style="color:#999;font-size:.75rem">加载中...</span>
</div>
</div>

<script>
(function(){
  var hc = document.getElementById('history-links');
  var xhr = new XMLHttpRequest();
  // 通过 Hexo 生成的 search.xml 查找带「天才杯」标签的文章
  xhr.open('GET','/search.xml?'+Date.now());
  xhr.onload = function(){
    try{
      var xml = xhr.responseXML || (new DOMParser()).parseFromString(xhr.responseText,'text/xml');
      var entries = xml.getElementsByTagName('entry');
      var links = [];
      for(var i=0;i<entries.length;i++){
        var e = entries[i];
        var tags = e.getElementsByTagName('tag');
        var isTcb = false;
        for(var j=0;j<tags.length;j++){
          if(tags[j].textContent === '天才杯'){ isTcb = true; break; }
        }
        if(!isTcb) continue;
        var title = e.getElementsByTagName('title')[0].textContent;
        var url = e.getElementsByTagName('url')[0].textContent;
        links.push({title:title,url:url});
      }
      if(links.length===0){
        hc.innerHTML = '<span style="color:#999;font-size:.78rem">暂无往届归档</span>';
        return;
      }
      var html='';
      links.forEach(function(l){
        html+='<a class="history-link" href="'+l.url+'">📄 '+l.title+'</a>';
      });
      hc.innerHTML = html;
    }catch(e){
      hc.innerHTML = '<span style="color:#999;font-size:.78rem">加载失败</span>';
    }
  };
  xhr.onerror = function(){ hc.innerHTML = '<span style="color:#999;font-size:.78rem">加载失败</span>'; };
  xhr.send();
})();
</script>
{% endraw %}
