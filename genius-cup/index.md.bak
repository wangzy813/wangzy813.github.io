<style>
:root{color-scheme:light}
/* ===== 深色模式变量 ===== */
[data-theme="dark"] #genius-cup{
  --gc-font:#e0e0e0;--gc-font-secondary:#aaa;
  --gc-bg:#1e1e1e;--gc-bg-secondary:#252525;--gc-border:#333;
  --gc-hover:rgba(255,255,255,.06);--gc-row1:rgba(255,215,0,.10);--gc-row2:rgba(255,255,255,.03);--gc-row3:rgba(205,127,50,.08);
}
/* ===== 浅色模式变量 ===== */
#genius-cup{
  --gc-font:#222;--gc-font-secondary:#888;
  --gc-bg:#fff;--gc-bg-secondary:#fafafa;--gc-border:#e8e8e8;
  --gc-hover:rgba(0,0,0,.04);--gc-row1:rgba(255,215,0,.08);--gc-row2:rgba(0,0,0,.02);--gc-row3:rgba(205,127,50,.05);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;max-width:860px;margin:0 auto
}
/* 统一替换所有变量引用 */
#genius-cup .cup-header h2{color:var(--gc-font)}
