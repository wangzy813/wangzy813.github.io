#genius-cup .cup-header .badge{display:inline-block;background:linear-gradient(135deg,#f5af19,#f12711);color:#fff;padding:3px 14px;border-radius:12px;font-size:.75rem;font-weight:600;margin-bottom:6px}
#genius-cup .cup-header h2{font-size:1.35rem;margin:6px 0 2px;color:var(--font-color,#222)}
#genius-cup .cup-header .meta{font-size:.74rem;color:var(--font-color-secondary,#999)}
/* 领奖台 */
#genius-cup .podium-row{display:flex;align-items:flex-end;justify-content:center;gap:12px;margin:24px 0 10px;flex-wrap:wrap}
