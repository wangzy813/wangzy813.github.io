<!-- 排名表 -->
<h3 style="text-align:center;font-size:.92rem;margin:20px 0 6px;color:#555">📋 完整排名</h3>
<div class="rank-wrap"><table class="rank-table"><thead><tr>
  <th>排名</th><th>股票</th><th>代码</th><th>选手</th><th>上月收盘</th><th>最新价</th><th>月涨幅</th>
</tr></thead><tbody id="ranking-body"><tr><td colspan="7" style="color:#999;padding:20px">⏳ 加载中...</td></tr></tbody></table></div>

