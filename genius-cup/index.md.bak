#genius-cup .podium-card .pc-stock{font-size:.72rem;color:var(--gc-font-secondary);margin:3px 0}
#genius-cup .podium-card .pc-chg{font-size:1.3rem;font-weight:700;margin:4px 0}
#genius-cup .podium-card.gold .pc-chg{font-size:1.6rem}
#genius-cup .podium-card .pc-footer{background:var(--gc-bg-secondary);padding:7px;font-size:.72rem;color:var(--gc-font-secondary)}
#genius-cup .podium-card.gold .pc-footer{background:linear-gradient(135deg,#fff9c4,#ffd54f);color:#888}
#genius-cup .up{color:#e53935!important}.down{color:#2e7d32!important}.na{color:var(--gc-font-secondary)}
/* 表格 */
#genius-cup .rank-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-top:20px}
#genius-cup table.rank-table{width:100%;border-collapse:collapse;font-size:.78rem;min-width:500px}
#genius-cup table.rank-table th{background:var(--gc-bg-secondary);padding:8px 6px;text-align:center;font-weight:600;color:var(--gc-font-secondary);border-bottom:2px solid var(--gc-border);white-space:nowrap}
#genius-cup table.rank-table td{padding:8px 6px;text-align:center;border-bottom:1px solid var(--gc-border)}
#genius-cup table.rank-table tr.row-1{background:var(--gc-row1)}
#genius-cup table.rank-table tr.row-2{background:var(--gc-row2)}
#genius-cup table.rank-table tr.row-3{background:var(--gc-row3)}
#genius-cup table.rank-table tr:hover{background:var(--gc-hover)!important}
/* 往届链接 */
#genius-cup .history-section{margin-top:40px;border-top:2px solid var(--gc-border);padding-top:20px}
#genius-cup .history-section h3{text-align:center;font-size:1.05rem;margin-bottom:14px;color:var(--gc-font)}
#genius-cup .history-links{display:flex;flex-wrap:wrap;gap:8px;justify-content:center}
#genius-cup .history-link{display:inline-block;padding:6px 16px;border-radius:18px;font-size:.78rem;background:var(--gc-bg-secondary);color:var(--gc-font);text-decoration:none;border:1px solid var(--gc-border);transition:all .2s}
#genius-cup .history-link:hover{background:var(--gc-bg);border-color:#ff9800;color:#e65100}
.footer-note{text-align:center;color:#aaa;font-size:.65rem;padding:14px;line-height:1.6}
@media(max-width:600px){
  #genius-cup .podium-row{gap:6px}
  #genius-cup .podium-card.bronze{width:110px}
  #genius-cup .podium-card.silver{width:130px}
  #genius-cup .podium-card.gold{width:150px}
  #genius-cup .podium-card .pc-player{font-size:.7rem}
  #genius-cup .podium-card.gold .pc-player{font-size:.78rem}
  #genius-cup .podium-card .pc-chg{font-size:.95rem}
  #genius-cup .podium-card.gold .pc-chg{font-size:1.15rem}
}
</style>

